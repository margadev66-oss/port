<%- include("partials/tools-head", {
  pageTitle,
  pageDescription,
  pageKeywords,
  canonicalUrl,
  ogImageUrl,
  siteData,
  assetRoutes,
  needsPdfLib: false,
  structuredDataJson
}) %>
<%- include("partials/tools-header", { siteData, assetRoutes, toolsCategories }) %>

    <main class="tools-main">
      <section class="tools-hero">
        <div class="page-wrap tools-hero__grid">
          <div class="tools-hero__copy">
            <span class="eyebrow"><%= toolsHub.eyebrow %></span>
            <h1><%= toolsHub.heading %></h1>
            <p class="tools-hero__intro"><%= toolsHub.intro %></p>

            <div class="tools-hero__actions">
              <a class="button button--primary" href="<%= toolsHub.primaryCtaHref %>"><%= toolsHub.primaryCtaLabel %></a>
              <a class="button button--secondary" href="<%= toolsHub.secondaryCtaHref %>"><%= toolsHub.secondaryCtaLabel %></a>
            </div>

            <div class="trust-list">
              <% toolsHub.trustPoints.forEach((point) => { %>
              <article class="trust-list__item">
                <span></span>
                <p><%= point %></p>
              </article>
              <% }) %>
            </div>
          </div>

          <aside class="tools-hero__panel">
            <div class="surface-card feature-panel">
              <span class="surface-card__eyebrow">Platform focus</span>
              <strong class="feature-panel__headline">A cleaner utility stack for direct-intent searches.</strong>
              <p class="feature-panel__lead">
                The current build spans image, PDF, QR, developer, AI, and asset workflows so users can move between adjacent tasks without jumping into a larger suite.
              </p>
              <div class="feature-panel__stats">
                <% toolsCategories.forEach((categoryItem) => { %>
                <article>
                  <strong><%= categoryItem.toolCount %></strong>
                  <span><%= categoryItem.name %></span>
                </article>
                <% }) %>
              </div>
            </div>

            <div class="surface-card feature-panel feature-panel--secondary">
              <span class="surface-card__eyebrow">What these pages solve</span>
              <div class="feature-panel__list">
                <article>
                  <strong>Strict upload limits</strong>
                  <span>Target-size image and PDF workflows for forms, portals, and faster publishing.</span>
                </article>
                <article>
                  <strong>Content cleanup</strong>
                  <span>Focused dev and AI pages for formatting payloads, summaries, metadata, and reusable copy.</span>
                </article>
                <article>
                  <strong>Faster repeat tasks</strong>
                  <span>Each page is built to finish one job quickly, then route users into the next related utility.</span>
                </article>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="section-shell" id="tool-categories">
        <div class="page-wrap">
          <div class="section-row">
            <div class="section-header section-header--compact">
              <span class="eyebrow">Browse by category</span>
              <h2>Built around repeat utility workflows.</h2>
              <p>Each category groups related tools so users can move from one exact task to the next without starting a new search.</p>
            </div>
            <a class="text-link" href="/about-tools">About the platform</a>
          </div>

          <div class="category-grid">
            <% toolsCategories.forEach((categoryItem) => { %>
            <article class="surface-card category-card">
              <div class="category-card__top">
                <div class="category-card__meta">
                  <span class="material-symbols-outlined"><%= categoryItem.icon %></span>
                  <span><%= categoryItem.toolCount %> tools</span>
                </div>
                <h3><%= categoryItem.name %></h3>
                <p><%= categoryItem.shortDescription %></p>
              </div>

              <div class="chip-row category-card__chips">
                <% categoryItem.tools.slice(0, 3).forEach((tool) => { %>
                <span class="chip"><%= tool.name %></span>
                <% }) %>
              </div>

              <div class="category-card__footer">
                <span>Exact-intent pages</span>
                <a class="text-link" href="<%= categoryItem.path %>">Open category</a>
              </div>
            </article>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="section-shell" id="popular-tools">
        <div class="page-wrap">
          <div class="section-row">
            <div class="section-header section-header--compact">
              <span class="eyebrow">Popular</span>
              <h2>Strong early-demand tools.</h2>
            </div>
            <p class="section-side-note">These pages map to high-intent search behavior and repeated utility tasks.</p>
          </div>

          <div class="hub-showcase">
            <div class="tool-grid" data-tool-search-root>
              <% toolsHub.popularTools.forEach((tool) => { %>
              <article class="surface-card tool-card" data-tool-search-item data-tool-name="<%= tool.name.toLowerCase() %> <%= tool.targetKeyword.toLowerCase() %>">
                <div class="tool-card__meta">
                  <span class="material-symbols-outlined"><%= tool.icon %></span>
                  <span><%= tool.categoryData.name %></span>
                </div>
                <h3><%= tool.name %></h3>
                <p><%= tool.description %></p>
                <div class="chip-row">
                  <span class="chip"><%= tool.targetKeyword %></span>
                  <span class="chip"><%= tool.processingMode === "browser" ? "Browser" : "Instant" %></span>
                </div>
                <a class="text-link" href="<%= tool.path %>">Open tool</a>
              </article>
              <% }) %>
            </div>

            <aside class="hub-rail">
              <article class="surface-card rail-card">
                <div class="rail-card__header">
                  <span class="eyebrow">Recently added</span>
                  <a class="text-link" href="/tools">All tools</a>
                </div>
                <div class="mini-list">
                  <% toolsHub.recentTools.forEach((tool) => { %>
                  <a class="mini-list__item" href="<%= tool.path %>">
                    <div>
                      <strong><%= tool.name %></strong>
                      <span><%= tool.categoryData.name %></span>
                    </div>
                    <small><%= tool.processingMode === "browser" ? "Local" : "Online" %></small>
                  </a>
                  <% }) %>
                </div>
              </article>

              <article class="surface-card rail-card">
                <div class="rail-card__header">
                  <span class="eyebrow">How it works</span>
                </div>
                <ol class="mini-steps">
                  <li>
                    <strong>Open the page</strong>
                    <span>Choose the exact workflow instead of navigating a suite.</span>
                  </li>
                  <li>
                    <strong>Run the task fast</strong>
                    <span>Use the tool immediately and finish the task in one pass.</span>
                  </li>
                  <li>
                    <strong>Move to the next task</strong>
                    <span>Follow related links into the next adjacent utility.</span>
                  </li>
                </ol>
              </article>
            </aside>
          </div>
        </div>
      </section>

      <section class="section-shell section-shell--muted">
        <div class="page-wrap">
          <%- include("partials/adsense-unit", { slot: "4626786192" }) %>
        </div>
      </section>

      <section class="section-shell" id="suggest-tool">
        <div class="page-wrap">
          <div class="section-row">
            <div class="section-header section-header--compact">
              <span class="eyebrow">Suggest a tool</span>
              <h2>Send the next tool idea directly.</h2>
              <p>Public suggestions can help shape the next pages in the tools platform. Share the exact task, search phrase, or workflow that should be built next.</p>
            </div>
            <p class="section-side-note">Suggestions from this form are mailed directly through the site mailbox so they land in the same review flow as project inquiries.</p>
          </div>

          <div class="suggestion-grid">
            <article class="surface-card suggestion-panel">
              <span class="surface-card__eyebrow">What to include</span>
              <h3>Useful suggestions are usually specific.</h3>
              <p>Short ideas are fine, but the best submissions describe the actual constraint people run into and what the tool should output.</p>
              <ul class="aside-checklist">
                <li>Name the exact tool or search phrase people would look for.</li>
                <li>Explain the use case, file limit, or workflow problem it should solve.</li>
                <li>Leave an email if you want a follow-up when the tool is built.</li>
              </ul>
            </article>

            <form class="surface-card suggestion-form control-stack" id="tool-suggestion-form" method="post" action="/api/tools/suggestions" novalidate>
              <div class="control-row">
                <label>
                  <span>Name</span>
                  <input type="text" name="name" maxlength="120" placeholder="Optional" />
                </label>
                <label>
                  <span>Email</span>
                  <input type="email" name="email" maxlength="160" placeholder="Optional, for follow-up" />
                </label>
              </div>

              <div class="control-row">
                <label>
                  <span>Suggested tool</span>
                  <input type="text" name="toolName" maxlength="160" placeholder="e.g. PDF page deleter" required />
                </label>
                <label>
                  <span>Category</span>
                  <select name="category">
                    <option value="">Choose a category</option>
                    <% toolsCategories.forEach((categoryItem) => { %>
                    <option value="<%= categoryItem.name %>"><%= categoryItem.name %></option>
                    <% }) %>
                    <option value="Other">Other</option>
                  </select>
                </label>
              </div>

              <label>
                <span>What should it do?</span>
                <textarea name="details" rows="6" maxlength="3000" placeholder="Describe the exact task, problem, or search intent this tool should solve." required></textarea>
              </label>

              <input type="hidden" name="sourcePage" value="<%= canonicalUrl %>#suggest-tool" />

              <label class="hp-field" aria-hidden="true">
                <span>Website</span>
                <input type="text" name="website" tabindex="-1" autocomplete="off" />
              </label>

              <div class="button-row">
                <button class="button button--primary" type="submit">Send suggestion</button>
              </div>

              <p class="status-line tool-suggestion-status" id="tool-suggestion-status" aria-live="polite">
                Suggestions from this section are sent to the Student Dev inbox for review.
              </p>
            </form>
          </div>
        </div>
      </section>

      <section class="section-shell">
        <div class="page-wrap">
          <div class="cta-band">
            <div>
              <span class="eyebrow">Student Dev Tools</span>
              <h2>Ready to build the platform out further?</h2>
              <p>Add image, PDF, QR, developer, and AI-backed utilities into a sharper toolbox.</p>
            </div>
            <div class="cta-band__actions">
              <a class="button button--primary" href="/about-tools">See how it works</a>
              <a class="button button--secondary" href="/#contact">Work with Student Dev</a>
            </div>
          </div>
        </div>
      </section>
    </main>

<%- include("partials/tools-footer", { siteData, assetRoutes, toolsCategories, year }) %>
